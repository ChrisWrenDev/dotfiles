{
	"$schema": "https://opencode.ai/config.json",

	"permission": {
		"*": "ask",

		"thoughts_sync": "ask",
		"thoughts_init": "ask",
		"thoughts_status": "allow",
		"spec_metadata": "allow",
		"worktree_create": "ask",
		"worktree_cleanup": "ask",

		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		},

		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"todoread": "allow",
		"todowrite": "allow",
		"lsp": "allow",

		"task": "allow",

		"edit": "ask",

		"bash": {
			"*": "ask",

			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git branch*": "allow",
			"git show*": "allow",
			"git rev-parse*": "allow",
			"git remote*": "allow",
			"git worktree list*": "allow",

			"ls *": "allow",
			"pwd": "allow",
			"which *": "allow",
			"cat *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"wc *": "allow",

			"make check*": "allow",
			"make test*": "allow",
			"make lint*": "allow",
			"make fmt*": "allow",
			"make build*": "allow",
			"make mocks*": "allow",

			"go build*": "allow",
			"go test*": "allow",
			"go mod*": "allow",
			"go vet*": "allow",
			"golangci-lint*": "allow",

			"npm run lint*": "allow",
			"npm run check*": "allow",
			"npm run test*": "allow",
			"npm run build*": "allow",
			"npm run typecheck*": "allow",
			"bun run lint*": "allow",
			"bun run check*": "allow",
			"bun run test*": "allow",
			"bun run build*": "allow",
			"bun run typecheck*": "allow",
			"npx tsc*": "allow",
			"npx vitest*": "allow",
			"npx jest*": "allow",

			"gh pr view*": "allow",
			"gh issue view*": "allow",
			"gh repo view*": "allow",
			"gh api *": "allow",

			"rm *": "deny",
			"rm -rf *": "deny",
			"sudo *": "deny",
			"chmod *": "deny",
			"chown *": "deny",
			"> *": "deny",
			"curl * | bash": "deny",
			"wget * | bash": "deny"
		},

		"webfetch": "ask",
		"websearch": "ask",
		"codesearch": "ask",

		"external_directory": "ask",
		"doom_loop": "ask"
	},

	"env": {
		"MAX_THINKING_TOKENS": "32000"
	},

	"enableAllProjectMcpServers": false
}
